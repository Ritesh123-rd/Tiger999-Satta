{
  "expo": {
    "name": "TIGER999",
    "icon": "./assets/logo/logo.png",
    "slug": "tiger999app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "updates": {
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.tiger999",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.yourcompany.tiger999",
      "versionCode": 10,
      "googleServicesFile": "./assets/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/splash.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo/logo.png",
          "color": "#FFFFFF",
          "defaultChannel": "default"
        }
      ]
    ],

    "extra": {
      "eas": {
        "projectId": "3eaddc7c-cb53-43b4-bb12-15e212b7f53b"
      }
    }
  }
}
